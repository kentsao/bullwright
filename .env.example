# Bullwright environment — copy to .env and fill in. NEVER commit .env.
# Every variable used anywhere in the codebase must be documented here.

# --- Core ---
BW_ENV=dev                      # dev | prod
BW_DB_URL=sqlite:///data/bullwright.db
BW_API_HOST=127.0.0.1           # keep localhost unless you know why not
BW_API_PORT=8600
BW_LOG_LEVEL=info

# --- Auth ---
# Operator bootstrap key is minted by `bw keys bootstrap` on first run,
# printed once, and stored hashed. Nothing to put here.

# --- Ollama (local models) ---
BW_OLLAMA_URL=http://127.0.0.1:11434
BW_LOCAL_MODEL=gemma4:12b-mlx
BW_EMBED_MODEL=nomic-embed-text

# --- Agent scripts (set in the shell/session of each agent) ---
# BW_API_URL=http://127.0.0.1:8600/v1
# BW_API_KEY=bw_live_...          # per-agent key, minted by operator

# --- Market data ---
BW_MARKET_PROVIDER=yfinance

# --- News & SEC signals (ADR-0002) ---
BW_NEWS_PROVIDER=rss            # rss | fixture
# SEC requires a descriptive User-Agent with a contact for data.sec.gov:
BW_EDGAR_UA="Bullwright (your-contact@example.com)"

# --- Billing (spec-only; keep disabled) ---
BW_BILLING_ENABLED=false
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
